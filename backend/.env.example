# Neon PostgreSQL (use pooler URL for Netlify/serverless)
DATABASE_URL=postgresql://user:password@ep-example-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

PORT=9002
NODE_ENV=development
SECRET=your_jwt_secret_here

# Local frontend
DEVELOPMENT_CLIENT_ORIGIN=http://localhost:3000
# Vercel production frontend
PRODUCTION_CLIENT_ORIGIN=https://siliconbazaar.vercel.app

# Public API URL (local dev / Netlify site URL in production)
API_PUBLIC_URL=https://siliconbazaar.netlify.app

# Google OAuth — add Netlify callback in Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:9002/api/auth/google/callback

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ImageKit (product images — required on Netlify; local fallback when unset)
IMAGEKIT_ID=your_imagekit_id
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_FOLDER=/siliconbazaar
